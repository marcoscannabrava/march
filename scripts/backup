#!/bin/bash
# Backup script: syncs $HOME dir with Backblaze

echo "-----> Running backup script on $(date +"%Y-%m-%d-%H:%M:%S")"

# Directories to backup (each synced in parallel)
DIRS=(".config" ".claude" ".codex" "code" "Documents" "Music")

# Common exclude patterns
EXCLUDES=(
    "--exclude=tmp/**"
    "--exclude=sandbox/**"
    "--exclude=go/**"
    "--exclude=apps/**"
    "--exclude=node_modules/**"
    "--exclude=__pycache__/**"
    "--exclude=miniconda3/**"
    "--exclude=VirtualBoxVMs/**"
    "--exclude=Downloads/**"
    "--exclude=canvas-lms/**"
)

# Sync each directory in a separate process
PIDS=()
for DIR in "${DIRS[@]}"; do
    echo "-----> Starting backup for: $DIR"
    rclone copy --copy-links --transfers 8 --max-buffer-memory 1G "${EXCLUDES[@]}" "$@" "$HOME/$DIR" "backblaze:poposbkp/$DIR" &
    PIDS+=($!)
done

# Wait for all processes to complete
FAILED=0
for PID in "${PIDS[@]}"; do
    wait $PID
    STATUS=$?
    if [ $STATUS -ne 0 ]; then
        FAILED=1
    fi
done

echo "-----> Backup finished on $(date +"%Y-%m-%d-%H:%M:%S")"
if command -v notify-send &> /dev/null
then
    if [ $FAILED -eq 1 ]; then
        notify-send "Backup completed with errors" "$(date +"%Y-%m-%d-%H:%M:%S")"
    else
        notify-send "Backup finished" "$(date +"%Y-%m-%d-%H:%M:%S")"
    fi
fi


# Command to Check backup size
